{
  "name": "bodega-la-pascuala",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "sveltekit-app",
    "studio"
  ],
  "scripts": {
    "backfill:order-item-keys": "node scripts/backfill-order-item-keys.mjs",
    "dev": "concurrently \"npm run dev --workspace=sveltekit-app\" \"npm run dev --workspace=studio\"",
    "format": "prettier --cache --write .",
    "import:bocadillos": "node scripts/import-bocadillos.mjs"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson"
    ],
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "3.3.3",
    "prettier-plugin-packagejson": "2.5.1"
  }
}
