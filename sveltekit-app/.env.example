# Required - The ID of your Sanity project
PUBLIC_SANITY_PROJECT_ID=""
# Required - The dataset of your Sanity project
PUBLIC_SANITY_DATASET=""
# Required - The generated read token, used to fetch data on the server
SANITY_API_READ_TOKEN=""
# Required - Sanity write token for creating/updating orders
SANITY_API_WRITE_TOKEN=""
# Optional - The Sanity API version to use
PUBLIC_SANITY_API_VERSION=""
# Optional - The URL of your Sanity Studio
PUBLIC_SANITY_STUDIO_URL=""

# Required - Stripe publishable key used in browser checkout
PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Required - Stripe secret key used by server routes
STRIPE_SECRET_KEY=""
# Required - Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=""
# Required - Secret used to sign order tracking tokens
TRACKING_TOKEN_SECRET=""
